{
  "sampleOnly": true,
  "domain": "sample-generic",
  "nodeTypes": [
    {
      "id": "SampleObject",
      "name": "样例对象",
      "summary": "用于展示一个可被查询和引用的节点类型样例。",
      "identityFields": ["id"],
      "queryableFields": ["id", "name", "status", "ownerId"]
    },
    {
      "id": "SampleContext",
      "name": "样例上下文",
      "summary": "用于展示一个可作为关联上下文的节点类型样例。",
      "identityFields": ["id"],
      "queryableFields": ["id", "category", "priority", "effectiveAt"]
    },
    {
      "id": "SampleEvent",
      "name": "样例事件",
      "summary": "用于展示一个事件型节点的样例。",
      "identityFields": ["id"],
      "queryableFields": ["id", "eventType", "createdAt", "relatedObjectId"]
    }
  ],
  "edgeTypes": [
    { "id": "RELATED_TO", "from": "SampleObject", "to": "SampleContext", "summary": "展示对象与上下文之间的一般关联。" },
    { "id": "OBSERVED_IN", "from": "SampleEvent", "to": "SampleObject", "summary": "展示事件与对象之间的一般关联。" },
    { "id": "DERIVED_FROM", "from": "SampleContext", "to": "SampleEvent", "summary": "展示上下文信息可能来源于某个事件。" }
  ]
}
